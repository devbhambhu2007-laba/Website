{
	"$schema": "https://schemas.wp.org/wp/6.6/theme.json",
	"version": 3,
	"title": "Dark",
	"settings": {
		"color": {
			"palette": [
				{ "slug": "background", "name": "Background", "color": "#1b120d" },
				{ "slug": "background-strong", "name": "Background Strong", "color": "#3b2114" },
				{ "slug": "surface", "name": "Surface", "color": "#2a1a13" },
				{ "slug": "surface-soft", "name": "Surface Soft", "color": "#3c2619" },
				{ "slug": "ink", "name": "Ink", "color": "#fff0cf" },
				{ "slug": "muted", "name": "Muted", "color": "#e4c6a4" },
				{ "slug": "line", "name": "Line", "color": "#8f6f4f" },
				{ "slug": "accent", "name": "Accent", "color": "#ff9f43" },
				{ "slug": "accent-strong", "name": "Accent Strong", "color": "#ffd166" },
				{ "slug": "blue", "name": "Blue", "color": "#e7b872" },
				{ "slug": "rose", "name": "Rose", "color": "#ff7a5c" },
				{ "slug": "warm", "name": "Warm", "color": "#4b2b18" },
				{ "slug": "highlight", "name": "Highlight", "color": "#ffc440" },
				{ "slug": "coral", "name": "Coral", "color": "#ff7a5c" },
				{ "slug": "orange", "name": "Orange", "color": "#ffb45a" },
				{ "slug": "white", "name": "White", "color": "#fff0cf" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|background",
			"text": "var:preset|color|ink"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var:preset|color|accent",
					"text": "var:preset|color|background"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|accent-strong"
				}
			}
		},
		"blocks": {
			"core/code": {
				"color": {
					"background": "var:preset|color|surface",
					"text": "var:preset|color|ink"
				}
			}
		}
	}
}
